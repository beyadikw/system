# ============================================================
#  إعدادات الإنتاج — خذ بيدي
#  انسخ هذا الملف إلى .env على الخادم واضبط القيم الحقيقية.
#  لا ترفع .env إلى Git إطلاقاً.
# ============================================================

# ===== الخادم =====
PORT=4000
NODE_ENV=production
# نطاقك الحقيقي (مع https)
CLIENT_ORIGIN=https://beyadik.kw
PUBLIC_BASE_URL=https://beyadik.kw

# ===== قاعدة بيانات MySQL =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=beyadik_app
DB_PASSWORD=ضع-كلمة-مرور-قاعدة-بيانات-قوية
DB_NAME=khudh_biyadi

# ===== المصادقة (JWT) =====
# تم توليد سرّ عشوائي جاهز أدناه — أو ولّد غيره:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=s9pVPjixMXLt4oLavZL8wFiPXWII1zB8G7JoiO628iC9kdqaVAaOxopMIqpsjx
JWT_EXPIRES_IN=7d

# ===== رفع الملفات =====
UPLOAD_DIR=uploads
MAX_FILE_MB=15

# ===== البريد الإلكتروني (SMTP حقيقي) =====
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=no-reply@beyadik.kw
SMTP_PASSWORD=كلمة-مرور-البريد
MAIL_FROM="مشروع خذ بيدي <no-reply@beyadik.kw>"
ADMIN_NOTIFY_EMAIL=coordinator@beyadik.kw

# كلمة مرور المنسّق الأولية عند البذر (غيّرها بعد أول دخول)
SEED_COORDINATOR_PASSWORD=ضع-كلمة-مرور-أولية-قوية
