# ===== الخادم =====
PORT=4000
NODE_ENV=development
# الرابط المسموح للواجهة الأمامية (CORS)
CLIENT_ORIGIN=http://localhost:4000
# الرابط العام للنظام (يُستخدم في روابط رفع التقرير المرسلة للجهات المنفّذة)
PUBLIC_BASE_URL=http://localhost:4000

# ===== قاعدة بيانات MySQL =====
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=khudh_biyadi
# على الاستضافة السحابية (Aiven مثلاً): قاعدة جاهزة + SSL
DB_SSL=false
DB_CREATE=true

# ===== التهيئة التلقائية عند الإقلاع (للاستضافة بلا طرفية) =====
AUTO_INIT=false
AUTO_SEED=false

# ===== المصادقة (JWT) =====
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# ===== رفع الملفات =====
UPLOAD_DIR=uploads
MAX_FILE_MB=15

# ===== البريد الإلكتروني (nodemailer / SMTP) =====
# اتركها فارغة في بيئة التطوير لطباعة الرسائل في الـ console بدل إرسالها
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM="مشروع خذ بيدي <no-reply@beyadik.kw>"
# بريد فريق المشروع لاستقبال إشعارات الطلبات الجديدة
ADMIN_NOTIFY_EMAIL=coordinator@beyadik.kw
